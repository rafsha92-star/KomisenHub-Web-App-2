rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isHardcodedAdmin() {
      return request.auth != null && (
        request.auth.uid == "Filg0XUiUIUDnfPkCD8sjnNqUtc2" ||
        (request.auth.token != null && 
         request.auth.token.email != null && (
           request.auth.token.email == "rafsha92@gmail.com" ||
           request.auth.token.email == "admin@komisyenhub.com" ||
           request.auth.token.email == "admin@example.com"
         )
        )
      );
    }

    function isAdmin() {
      return isHardcodedAdmin() || (
        request.auth != null && 
        request.auth.token != null && 
        request.auth.token.email != null && 
        exists(/databases/$(database)/documents/admins/$(request.auth.token.email))
      );
    }

    // 1. Users Collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());
    }

    // 2. Offers Collection
    match /offers/{offerId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      allow update: if request.auth != null && resource.data.ownerId == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || isAdmin());
    }

    // 3. Favorites Collection
    match /favorites/{favoriteId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 4. Admins Collection
    match /admins/{email} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.token.email == "rafsha92@gmail.com" || isAdmin());
    }
  }
}
